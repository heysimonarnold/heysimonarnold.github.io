---
// src/pages/recettes/index.astro
import PageListing from "@/components/PageListing.astro";
import PageListingFilters from "@/components/PageListingFilters.astro";
import type { PageListingItem } from "@/configs/pageListing";
import DefaultLayout from "@/layouts/DefaultLayout.astro";
import { getCollection } from "astro:content";

const collection = await getCollection("recettes");
console.log(collection);
// Optional: filter by top-level (no `/` in slug) if you want folder separation
const topLevelEntries = collection.filter((e) => !e.slug.includes("/"));

const items: PageListingItem[] = topLevelEntries.map((entry) => ({
  title: entry.data.title,
  slug: entry.slug,
  tags: entry.data?.tags,
}));
---

<DefaultLayout title="Recettes" type="page">
  <slot slot="after-pager-header">
    <PageListingFilters name="protein" items={["🐮", "🐔", "🐷", "🐟", "🌱"]} />
  </slot>
  <PageListing basePath="/recettes" id="recipes-list" items={items} />
</DefaultLayout>

<script>
  const proteinRadioBtns = document.querySelectorAll('input[name="protein"]');
  const recipesList = document.getElementById("recipes-list");
  const recipes = recipesList?.querySelectorAll("li") || [];

  proteinRadioBtns.forEach((radio) => {
    radio.addEventListener("change", (event) => {
      recipes.forEach((recipe) => {
        const tags = recipe.getAttribute("data-tags")?.split(",") || [];
        const selectedProtein = (event.target as HTMLInputElement).value;

        if (selectedProtein === "all" || tags.includes(selectedProtein)) {
          recipe.style.display = "";
        } else {
          recipe.style.display = "none";
        }
      });
    });
  });
</script>
